# ==================== ENVIRONMENT ====================
# Chọn: development, staging, production
ENVIRONMENT=development

# ==================== SERVER SETTINGS ====================
HOST=0.0.0.0
PORT=5000

# SECRET_KEY MUST be set in production - generate with: openssl rand -hex 32
# Development can use default, but NEVER hardcode in production
SECRET_KEY=your-very-secret-key-change-this-in-production

# ==================== MODEL PATHS ====================
# Nếu không set, sẽ dùng giá trị mặc định (relative paths)
# Ví dụ production:
# MODEL_PATH_SHAPE=/models/bmi_finetuned_model.pth
# MODEL_PATH_REP_COUNTER=/models/phase_model.pt
# MODEL_PATH_BODY_DETECT=/models/best.pt

MODEL_PATH_SHAPE=bmi_finetuned_model.pth
MODEL_PATH_POSE=yolov8n-pose.pt
MODEL_PATH_REP_COUNTER=ai_rep_counter/models/phase_model.pt
MODEL_PATH_BODY_DETECT=best.pt

# ==================== API KEYS & CREDENTIALS ====================
# Gemini API key để sử dụng cho recommendation system
# REQUIRED in production
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model version - consistent across all services
GEMINI_MODEL=gemini-1.5-flash

# Use Gemini proxy (gemini-web2api) or call Google API directly
# Chọn: true (sử dụng proxy), false (gọi trực tiếp)
USE_GEMINI_PROXY=false

# ==================== INTERNAL SERVICE URLS ====================
# Nếu dùng Docker: http://gemini-proxy:8082 (service name)
# Nếu chạy local: http://127.0.0.1:8082
GEMINI_PROXY_URL=http://127.0.0.1:8082

# URL cho Web2API service
WEB2API_URL=http://localhost:8085/v1/chat/completions

# ==================== DATABASE ====================
# SQLite (development only)
# DATABASE_URL=sqlite:///app.db

# PostgreSQL (production REQUIRED)
# Generate strong password: openssl rand -base64 32
# DATABASE_URL=postgresql://vfit_user:strong-password-here@db:5432/vfit_db

DATABASE_URL=sqlite:///app.db

# PostgreSQL credentials (if using docker-compose.prod.yml)
# DB_USER and DB_PASSWORD MUST be set in production
DB_USER=vfit_user
DB_PASSWORD=change-this-to-strong-password
DB_NAME=vfit_db

# Redis password (MUST be set in production)
REDIS_PASSWORD=change-this-to-strong-password

# ==================== CORS SETTINGS ====================
# Development: * (allow all)
# Staging: https://staging.example.com
# Production: https://yourdomain.com,https://app.yourdomain.com
# REQUIRED in production
CORS_ORIGINS=*

# ==================== LOGGING ====================
# Chọn: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Max size per log file (bytes) - default 10MB
LOG_MAX_BYTES=10485760

# Number of backup log files to keep - default 5
LOG_BACKUP_COUNT=5

# ==================== RETRY & TIMEOUT SETTINGS ====================
# Number of retry attempts for failed requests
RETRY_ATTEMPTS=3

# Initial delay between retries (seconds)
RETRY_DELAY_SEC=2.0

# Request timeout (seconds) - for API calls to Gemini, etc
REQUEST_TIMEOUT_SEC=180.0

# ==================== REQUEST SETTINGS ====================
# Maximum content length (bytes) - mặc định 16MB
MAX_CONTENT_LENGTH=16777216

# Request timeout (seconds) - mặc định 300s (5 minutes)
REQUEST_TIMEOUT=300

# ==================== FILE UPLOAD ====================
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE=10485760

# ==================== SSL/TLS SETTINGS (Production) ====================
# Paths to SSL certificates for Nginx
# REQUIRED in production with docker-compose.prod.yml
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# ==================== DOCKER SETTINGS ====================
# Sử dụng trong docker-compose.yml
DOCKER_REGISTRY=your-registry.com
IMAGE_TAG=latest

# ==================== PRODUCTION DEPLOYMENT NOTES ====================
# Before deploying to production:
# 1. Generate SECRET_KEY: openssl rand -hex 32
# 2. Set ENVIRONMENT=production
# 3. Set GEMINI_API_KEY with valid API key
# 4. Set CORS_ORIGINS with your actual domain(s)
# 5. Set strong DB_PASSWORD and REDIS_PASSWORD
# 6. Set DATABASE_URL with PostgreSQL connection string
# 7. Configure SSL certificates at SSL_CERT_PATH and SSL_KEY_PATH
# 8. NEVER commit .env files to version control
# 9. Use strong, randomly generated passwords for all credentials
# 10. Test all environment variables before deployment
