SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
APP_NAME=V-FIT
APP_BASE_URL=https://api.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Recommended for real production: MongoDB Atlas SRV URI.
# Example: mongodb+srv://vfit_app:<strong_password>@cluster0.xxxxx.mongodb.net/vfit?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://vfit_app:<strong_password>@<cluster-host>/vfit?retryWrites=true&w=majority&maxPoolSize=100&minPoolSize=10&maxIdleTimeMS=60000&serverSelectionTimeoutMS=5000
REDIS_HOST=redis-or-managed-cache-host
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_REQUIRED=true
REDIS_HEALTH_ENABLED=true
EXERCISE_LIBRARY_CACHE_TTL_SECONDS=86400
AI_RATE_LIMIT_MAX_REQUESTS=60
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_RATE_LIMIT_FAIL_OPEN=false
AI_CLIENT_MODE=http
AI_BASE_URL=https://ai-api.your-domain.com
AI_FOOD_SCANNER_PATH=/api/v1/food-scanner/

JWT_SECRET=replace_with_a_very_long_random_secret_at_least_64_bytes
OTP_PEPPER=replace_with_another_long_random_secret_for_otp_hashing
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
UPLOAD_DIR=/app/uploads

OPENAPI_ENABLED=false
SWAGGER_UI_ENABLED=false

# Enable once for first production bootstrap, then set false and redeploy.
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@vfit.com
BOOTSTRAP_ADMIN_PASSWORD=replace_with_strong_admin_password
BOOTSTRAP_ADMIN_FULL_NAME=V-FIT Admin
BOOTSTRAP_PUBLIC_CONFIG_ENABLED=true
BOOTSTRAP_SAMPLE_DATA_ENABLED=false
BOOTSTRAP_APP_NAME=V-FIT
BOOTSTRAP_APP_SLOGAN=Train smarter, live healthier
BOOTSTRAP_SUPPORT_EMAIL=support@your-domain.com
BOOTSTRAP_TERMS_URL=https://your-domain.com/terms
BOOTSTRAP_PRIVACY_URL=https://your-domain.com/privacy
BOOTSTRAP_LATEST_VERSION=1.0.0
BOOTSTRAP_MIN_SUPPORTED_VERSION=1.0.0

GOOGLE_CLIENT_ID=replace_with_google_web_oauth_client_id
FACEBOOK_APP_ID=replace_with_facebook_app_id
FACEBOOK_APP_SECRET=replace_with_facebook_app_secret

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SEPAY_WEBHOOK_SECRET=replace_with_sepay_webhook_secret
SEPAY_BANK_CODE=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
VIETQR_BASE_URL=https://img.vietqr.io/image
PAYMENT_EXPIRY_MINUTES=15
PAYMENT_VOUCHER_EXPIRY_SCAN_DELAY_MS=60000
